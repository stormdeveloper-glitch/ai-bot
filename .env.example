# .env.example — nusxalab .env nomini bering

# @BotFather dan olingan token
BOT_TOKEN=1234567890:ABCDEFGHIJKLMNabcdefghijklmn

# Admin Telegram ID lari (vergul bilan ajrating)
ADMIN_IDS=123456789,987654321

# Google AI Studio dan olingan API kalit (bepul)
# https://aistudio.google.com/app/apikey
GEMINI_API_KEY=AIzaSyXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# OpenWeatherMap API kalit (bepul, 1000 so'rov/kun)
# https://openweathermap.org/api
WEATHER_API_KEY=your_openweathermap_api_key_here

# Standart shahar (ixtiyoriy, default: Toshkent)
WEATHER_CITY=Toshkent

# Google Imagen API (rasm generatsiyasi) — xuddi shu Gemini kalit ishlaydi!
NANO_BANANA_API_KEY=your_google_ai_studio_key_here
